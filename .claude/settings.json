{
  "hooks": {
    "SessionStart": [
      {
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/load-context.sh\"",
        "description": "Load project context and last session notes"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/hooks/auto-tmux-dev.sh\"",
        "description": "Suggest tmux for dev server commands"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/hooks/quality-gate.sh\"",
        "description": "Auto-format and typecheck after file edits"
      },
      {
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/hooks/suggest-compact.sh\"",
        "description": "Suggest /compact at ~50 tool calls"
      },
      {
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/hooks/observe.sh\"",
        "description": "Log tool usage for continuous learning"
      }
    ],
    "Stop": [
      {
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/save-summary.sh\"",
        "description": "Auto-save session summary"
      },
      {
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/hooks/cost-tracker.sh\"",
        "description": "Track session metrics"
      },
      {
        "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.claude/hooks/extract-instincts.sh\"",
        "description": "Extract learning patterns from session"
      }
    ]
  }
}
